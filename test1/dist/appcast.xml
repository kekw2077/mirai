          <li>Голосовой ввод и команды (через Python-сайдкар).</li>
        </ul>
      ]]></description>
      <pubDate>Tue, 30 Jun 2026 12:05:07 +0000</pubDate>
      <enclosure
        url="https://github.com/kekw2077/mirai/releases/download/desktop-v1.0.0/EVS-Setup-1.0.0.exe"
        sparkle:version="1.0.0"
        sparkle:os="windows"
        sparkle:dsaSignature="MDwCHCU/YBSi4gQTpfRyIyGGdLGyEu4pButMkNiADa8CHFJIiIauamt0vQL8yJkJ7+TXt+VssGdvzoH5XVc="
